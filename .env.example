# ╔══════════════════════════════════════════════════════════════════╗
# ║  ITパス理解ノート — 環境変数テンプレート                          ║
# ║                                                                    ║
# ║  ローカル開発:  cp .env.example .env.local  → 値を埋める          ║
# ║  Vercel 本番:   Project → Settings → Environment Variables に登録 ║
# ╚══════════════════════════════════════════════════════════════════╝


# ───────────────────────────────────────────────────────────────────
# 【必須】アプリを起動するために最低限これだけあれば動く
# ───────────────────────────────────────────────────────────────────

# Neon Postgres の接続文字列。
#   取得元: https://neon.tech → プロジェクト作成 → Connection string
#   本番では "Pooled connection" URL を使うこと (PgBouncer 経由)。
#   末尾に ?sslmode=require を必ず付ける。
DATABASE_URL="postgres://user:password@host.neon.tech/dbname?sslmode=require"

# セッション Cookie (itpas_session) の署名に使う秘密鍵。
#   生成: openssl rand -base64 48
#   32文字以上が必須。複数デプロイで同じ値を使うこと。
#   ローテートすると全ユーザのセッションが失効する。
AUTH_SECRET=""

# Google OAuth 2.0 クライアント認証情報。
#   作成: https://console.cloud.google.com/apis/credentials
#     → "OAuth 2.0 クライアントID" → Webアプリケーション
#   承認済みリダイレクト URI に以下を登録:
#     http://localhost:3000/api/auth/google/callback
#     https://{本番ドメイン}/api/auth/google/callback
#   承認済み JavaScript 生成元にも本番ドメインを登録。
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""


# ───────────────────────────────────────────────────────────────────
# 【任意】本番運用で追加設定が必要なもの
# ───────────────────────────────────────────────────────────────────

# 公開サイト URL (OG画像 / サイトマップ用の絶対URL)。
#   Vercel では $VERCEL_URL に自動フォールバックするので未設定でもOK。
#   カスタムドメインを使う場合は明示的に入れた方が安全。
NEXT_PUBLIC_SITE_URL=""

# OAuth のリダイレクト URI を上書きしたいとき (プロキシや独自ドメイン経由)。
#   未設定なら `${request.origin}/api/auth/google/callback` が使われる。
GOOGLE_REDIRECT_URI=""


# ───────────────────────────────────────────────────────────────────
# 【Stripe / マネタイズ】
# 未設定だと /pricing のアップグレードボタンは "準備中" 表示に変わる。
# プランは全て月額のみ (年額はサポートしていません)。
# ───────────────────────────────────────────────────────────────────

# Stripe シークレットキー。
#   取得元: https://dashboard.stripe.com/apikeys
#   テスト中は sk_test_..., 本番は sk_live_... を使う。
STRIPE_SECRET_KEY=""

# Webhook エンドポイントの署名シークレット。
#   作成: Stripe ダッシュボード → Developers → Webhooks
#     → エンドポイント URL に {本番URL}/api/stripe/webhook を登録
#     → 購読イベント: checkout.session.completed,
#                    customer.subscription.created,
#                    customer.subscription.updated,
#                    customer.subscription.deleted
#     → Signing secret (whsec_...) をここにコピー
#   未設定でも動くが、本番では必ず設定すること (署名検証スキップになる)。
STRIPE_WEBHOOK_SECRET=""

# Pro プラン (月額 ¥780) の Price ID。
#   作成: Stripe ダッシュボード → Product catalog → 商品を作成
#     → Recurring / monthly / JPY 780 → Price ID (price_...) をコピー
STRIPE_PRICE_PRO_MONTHLY=""

# Premium プラン (月額 ¥1,980) の Price ID。
STRIPE_PRICE_PREMIUM_MONTHLY=""


# ───────────────────────────────────────────────────────────────────
# 【参考】Vercel に設定するときの環境スコープ
# ───────────────────────────────────────────────────────────────────
# Production, Preview, Development を個別に切り替え可能。
# 推奨:
#   - DATABASE_URL:          Production は本番DB, Preview は dev ブランチDB
#   - AUTH_SECRET:           3環境で同じ値 (異なるとセッションが切れる)
#   - GOOGLE_CLIENT_*:       Production と Preview/Dev を分けたいなら OAuth
#                            クライアントも2つ作成し、リダイレクトURIを
#                            それぞれに登録する
#   - STRIPE_*:              Production = sk_live_, Preview/Dev = sk_test_
#   - STRIPE_WEBHOOK_SECRET: Production / テスト で別の Webhook を作ること
