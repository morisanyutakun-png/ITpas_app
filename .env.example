# ===== Required =====

# Neon Postgres connection string. Get one at https://neon.tech
# Use the "Pooled connection" URL for production runtime.
DATABASE_URL="postgres://user:password@host.neon.tech/dbname?sslmode=require"

# Secret used to sign session cookies. Generate with:
#   openssl rand -base64 48
# Must be at least 32 characters. Rotating invalidates existing sessions.
AUTH_SECRET=""

# Google OAuth 2.0 credentials. Create at:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match {SITE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ===== Optional =====

# Public absolute URL for OG/sitemap.
# On Vercel, leave empty — the runtime will fall back to https://$VERCEL_URL.
NEXT_PUBLIC_SITE_URL=""

# Override the OAuth redirect URI (useful when behind a proxy or custom domain).
# Defaults to `${request.origin}/api/auth/google/callback`.
GOOGLE_REDIRECT_URI=""

# ===== Stripe (monetization) =====
# If unset, the Pro upgrade buttons are shown but disabled, and a helpful
# "not yet configured" banner appears on /pricing.

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Stripe Price IDs for the Pro plan (Subscription).
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
# Stripe Price IDs for the Premium plan (Subscription).
STRIPE_PRICE_PREMIUM_MONTHLY=""
STRIPE_PRICE_PREMIUM_YEARLY=""
