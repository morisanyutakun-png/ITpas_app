# Required: Neon Postgres connection string. Get one at https://neon.tech
# Use the "Pooled connection" URL for production runtime.
DATABASE_URL="postgres://user:password@host.neon.tech/dbname?sslmode=require"

# Optional: Public absolute URL for OG/sitemap.
# On Vercel, leave empty — the runtime will fall back to https://$VERCEL_URL.
# For a custom domain, set this to e.g. https://itpas-note.example.com
NEXT_PUBLIC_SITE_URL=""
